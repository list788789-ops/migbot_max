# Токен бота, полученный через @MasterBot внутри MAX
MAX_BOT_TOKEN=

# Домен API MAX. С 19.07.2026 старый platform-api.max.ru отключается — используем новый сразу.
MAX_API_BASE=https://platform-api2.max.ru

# Строка подключения к БД. Для первого скелета — sqlite, для продакшена — postgres.
DATABASE_URL=sqlite:///./migbot.db

# Список Telegram/MAX user_id или номеров, которым разрешена роль "кадровик"/"прораб".
# На первом этапе — простой список через запятую, потом переносим в таблицу users с ролями.
HR_PHONE_WHITELIST=

# Версия текста согласия на обработку персональных данных — нужна для аудита (consents.consent_text_version)
CONSENT_TEXT_VERSION=v1
